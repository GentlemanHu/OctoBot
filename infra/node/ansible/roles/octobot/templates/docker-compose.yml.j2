services:
  octobot:
    image: {{ octobot_image }}:{{ octobot_image_tag }}
    entrypoint: ["/bin/bash", "-c"]
    command:
      - |
        if [ -n "$${OCTOBOT_CONFIG}" ]; then
          echo "$$OCTOBOT_CONFIG" > /octobot/user/config.json
        fi
        bash tunnel.sh
        exec OctoBot node \
{% if is_master | default(false) | bool %}
          --master \
{% endif %}
{% if is_consumer_only | default(false) | bool %}
          --consumer_only true \
{% endif %}
          --host 0.0.0.0 \
          --port {{ octobot_node_port }}
    env_file: .env
    ports:
      - "{{ '127.0.0.1' if (enable_nginx | default(false) | bool) else '0.0.0.0' }}:{{ octobot_node_port }}:{{ octobot_node_port }}"
{% if expose_web_ui | default(false) | bool %}
      - "{{ '127.0.0.1' if (enable_nginx | default(false) | bool) else '0.0.0.0' }}:{{ octobot_web_port }}:{{ octobot_web_port }}"
{% endif %}
    volumes:
      - octobot_user:/octobot/user
      - octobot_tentacles:/octobot/tentacles
      - octobot_logs:/octobot/logs
    restart: always
    mem_limit: {{ octobot_mem_limit }}
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://127.0.0.1:{{ octobot_node_port }}/api/v1/openapi.json"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 60s
{% if enable_tor | default(false) | bool %}
    depends_on:
      - tor
{% endif %}
    networks:
      - frontend
{% if enable_replica_mode | default(false) | bool %}
      - backend
{% endif %}
{% if enable_tor | default(false) | bool %}
      - tor_net
{% endif %}

{% if enable_nginx | default(false) | bool %}
  nginx:
    image: {{ nginx_image }}
    ports:
      - "{{ nginx_port }}:{{ nginx_port }}"
      - "{{ nginx_ssl_port }}:{{ nginx_ssl_port }}"
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - ./origin.crt:/etc/nginx/certs/origin.crt:ro
      - ./origin.key:/etc/nginx/certs/origin.key:ro
    depends_on:
      octobot:
        condition: service_healthy
    restart: always
    mem_limit: {{ nginx_mem_limit }}
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - SETUID
      - SETGID
      - NET_BIND_SERVICE
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://127.0.0.1:{{ nginx_port }}/health"]
      interval: 10s
      retries: 5
    networks:
      - frontend
{% endif %}

{% if enable_tor | default(false) | bool %}
  tor:
    build:
      context: ./tor-proxy
    restart: always
    mem_limit: {{ tor_mem_limit }}
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    networks:
      - tor_net
{% endif %}

{% if enable_replica_mode | default(false) | bool and is_master | default(false) | bool %}
  postgres:
    image: {{ postgres_image }}
    restart: always
    environment:
      POSTGRES_DB: {{ postgres_db }}
      POSTGRES_USER: {{ postgres_user }}
      POSTGRES_PASSWORD: "{{ postgres_password }}"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    ports:
      - "{{ postgres_listen_address }}:5432:5432"
    mem_limit: {{ postgres_mem_limit }}
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ postgres_user }}"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - backend
{% endif %}

volumes:
  octobot_user:
  octobot_tentacles:
  octobot_logs:
{% if enable_replica_mode | default(false) | bool and is_master | default(false) | bool %}
  postgres_data:
{% endif %}

networks:
  frontend:
{% if enable_replica_mode | default(false) | bool %}
  backend:
{% endif %}
{% if enable_tor | default(false) | bool %}
  tor_net:
{% endif %}
