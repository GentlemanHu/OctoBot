server_tokens off;

upstream octobot_api {
    server octobot:{{ octobot_node_port }};
}

{% if expose_web_ui | default(false) | bool %}
upstream octobot_web {
    server octobot:{{ octobot_web_port }};
}
{% endif %}

limit_req_zone $binary_remote_addr zone=node_global:10m rate=50r/s;

server {
    listen {{ nginx_port }};
    server_name _;

    # Health endpoint — plain 200, no app info leaked
    location = /health {
        access_log off;
        return 200 "ok";
    }

    # Redirect HTTP → HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen {{ nginx_ssl_port }} ssl;
    server_name _;

    ssl_certificate /etc/nginx/certs/origin.crt;
    ssl_certificate_key /etc/nginx/certs/origin.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    client_max_body_size 10m;

    # Security headers
    add_header X-Frame-Options SAMEORIGIN always;
    add_header X-Content-Type-Options nosniff always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src 'self' wss:" always;

    # Health endpoint — plain 200, no app info leaked
    location = /health {
        access_log off;
        return 200 "ok";
    }

    # Node API
    location /api/ {
        proxy_pass http://octobot_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        limit_req zone=node_global burst=20 nodelay;
    }

{% if expose_web_ui | default(false) | bool %}
    # Web UI (catch-all)
    location / {
        proxy_pass http://octobot_web;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        limit_req zone=node_global burst=50 nodelay;
    }
{% else %}
    # Web UI disabled (expose_web_ui: false)
    location / {
        return 403;
    }
{% endif %}
}
