NODE_ENVIRONMENT=production
IS_MASTER_MODE={{ 'true' if (is_master | default(false) | bool) else 'false' }}
CONSUMER_ONLY={{ 'true' if (is_consumer_only | default(false) | bool) else 'false' }}
SECRET_KEY="{{ secret_key }}"
ADMIN_USERNAME="{{ admin_username }}"
ADMIN_PASSWORD="{{ admin_password }}"
BACKEND_HOST=http://{{ inventory_hostname }}:{{ octobot_node_port }}
BACKEND_CORS_ORIGINS={{ backend_cors_origins | default('') }}

# Database
{% if enable_replica_mode | default(false) | bool %}
SCHEDULER_POSTGRES_URL="postgresql://{{ postgres_user }}:{{ postgres_password | urlencode }}@{{ postgres_host }}:5432/{{ postgres_db }}"
{% else %}
SCHEDULER_SQLITE_FILE=tasks.db
{% endif %}

{% if disable_telemetry | default(false) | bool %}
# Telemetry disabled
SENTRY_DSN=
{% endif %}

{% if enable_tor | default(false) | bool %}
# Tor SOCKS5 proxy for exchange traffic
EXCHANGE_SOCKS_PROXY_AUTHENTICATED_URL=socks5h://tor:9050
USE_AUTHENTICATED_EXCHANGE_REQUESTS_ONLY_PROXY=False
{% endif %}

# Tentacles
{% if additional_tentacles_package_url | default('') | length > 0 %}
ADDITIONAL_TENTACLES_PACKAGE_URL={{ additional_tentacles_package_url }}
{% endif %}
{% if not (install_default_tentacles | default(true) | bool) %}
INSTALL_DEFAULT_TENTACLES=false
{% endif %}

# Task encryption (optional)
{% if tasks_inputs_rsa_private_key | default('') | length > 0 %}
TASKS_INPUTS_RSA_PRIVATE_KEY="{{ tasks_inputs_rsa_private_key }}"
TASKS_INPUTS_ECDSA_PUBLIC_KEY="{{ tasks_inputs_ecdsa_public_key }}"
TASKS_OUTPUTS_RSA_PUBLIC_KEY="{{ tasks_outputs_rsa_public_key }}"
TASKS_OUTPUTS_ECDSA_PRIVATE_KEY="{{ tasks_outputs_ecdsa_private_key }}"
TASKS_INPUTS_RSA_PUBLIC_KEY="{{ tasks_inputs_rsa_public_key }}"
TASKS_INPUTS_ECDSA_PRIVATE_KEY="{{ tasks_inputs_ecdsa_private_key }}"
TASKS_OUTPUTS_RSA_PRIVATE_KEY="{{ tasks_outputs_rsa_private_key }}"
TASKS_OUTPUTS_ECDSA_PUBLIC_KEY="{{ tasks_outputs_ecdsa_public_key }}"
{% endif %}
