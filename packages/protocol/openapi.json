        "description": "Optional holdings and volatility thresholds used for automations / stop behavior.",
        "type": "object",
        "properties": {
          "min_base_holding": {
            "type": "number",
            "minimum": 0,
            "default": 0
          },
          "min_quote_holding": {
            "type": "number",
            "minimum": 0,
            "default": 0
          },
          "max_positive_percent_price_change": {
            "type": "number",
            "minimum": 0,
            "default": 0
          },
          "max_negative_percent_price_change": {
            "type": "number",
