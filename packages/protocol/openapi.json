        "required": [
          "min_amount",
          "max_amount",
          "min_interval_seconds",
          "max_interval_seconds"
        ],
        "properties": {
          "min_amount": {
            "type": "number",
            "minimum": 0,
            "default": 0
          },
          "max_amount": {
            "type": "number",
            "minimum": 0,
            "default": 0
          },
          "min_interval_seconds": {
            "type": "number",
            "minimum": 0,
            "default": 0
          },
          "max_interval_seconds": {
            "type": "number",
            "minimum": 0,
            "default": 0
          }
        }
      },
