      "TaskStatus": {
        "description": "TaskStatus",
        "type": "string",
        "enum": [
          "pending",
          "scheduled",
          "periodic",
          "running",
          "completed",
          "failed"
        ]
      },
      "Side": {
        "description": "Order execution side.",
        "type": "string",
        "enum": [
          "buy",
          "sell"
        ]
      },
      "OrderType": {
        "description": "Exchange order type.",
        "type": "string",
        "enum": [
          "limit",
          "market",
          "stop_loss",
          "stop_loss_limit",
          "take_profit",
          "take_profit_limit"
        ]
      },
      "OrderStatus": {
        "description": "Lifecycle state of an order.",
        "type": "string",
        "enum": [
          "pending_creation",
          "open",
          "partially_filled",
          "filled",
          "canceled",
          "canceling",
          "closed",
          "expired",
          "rejected",
          "unknown"
        ]
      },
      "TrailingProfileType": {
        "description": "Trailing profile discriminator (mirrors octobot_trading TrailingProfileTypes values).",
        "type": "string",
        "enum": [
          "filled_take_profit"
